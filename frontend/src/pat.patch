:root {
  --font-main: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --color-bg: #f6f8ff;
  --color-surface: #ffffff;
  --color-surface-strong: #eef3ff;
  --color-text: #101828;
  --color-muted: #667085;
  --color-primary: #5f49f2;
  --color-primary-dark: #3f2ec7;
  --color-accent: #19c6c2;
  --color-warning: #b54708;
  --color-danger: #c92a2a;
  --color-border: rgba(95, 73, 242, 0.16);
  --shadow: 0 24px 70px rgba(32, 42, 92, 0.14);
  --radius-lg: 32px;
  --radius: 20px;
  --radius-sm: 14px;
  --transition: 0.25s ease;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  background:
    radial-gradient(circle at top left, rgba(25, 198, 194, 0.22), transparent 34rem),
    radial-gradient(circle at top right, rgba(95, 73, 242, 0.2), transparent 30rem),
    var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-main);
}

button,
input {
  font: inherit;
}

button,
a {
  transition:
    transform var(--transition),
    box-shadow var(--transition),
    background var(--transition),
    color var(--transition),
    border-color var(--transition);
}

a {
  color: inherit;
  text-decoration: none;
}

button {
  cursor: pointer;
}

.app {
  min-height: 100vh;
}

.shell {
  width: min(1180px, calc(100% - 40px));
  margin: 0 auto;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 50;
  border-bottom: 1px solid rgba(255, 255, 255, 0.75);
  background: rgba(246, 248, 255, 0.82);
  backdrop-filter: blur(18px);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  padding: 18px 0;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  border: 0;
  background: transparent;
  color: var(--color-text);
  font-size: 1.12rem;
  font-weight: 800;
  padding: 0;
}

.brand-mark {
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
  box-shadow: 0 12px 28px rgba(95, 73, 242, 0.28);
}

.nav {
  display: flex;
  align-items: center;
  gap: 24px;
  color: var(--color-muted);
  font-weight: 700;
}

.nav a:hover {
  color: var(--color-primary);
}

.header-actions,
.hero-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.primary-button,
.ghost-button,
.text-button,
.delete-card {
  border: 0;
  border-radius: 999px;
  font-weight: 800;
}

.primary-button {
  background: linear-gradient(135deg, var(--color-primary), #8e6cff);
  color: #fff;
  padding: 12px 20px;
  box-shadow: 0 14px 34px rgba(95, 73, 242, 0.28);
}

.primary-button:hover:not(:disabled) {
  transform: translateY(-2px);
  background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
}

.primary-button:disabled {
  cursor: not-allowed;
  opacity: 0.65;
}

.primary-button.large {
  padding: 16px 26px;
}

.primary-button.wide {
  width: 100%;
}

.ghost-button {
  border: 1px solid var(--color-border);
  background: rgba(255, 255, 255, 0.75);
  color: var(--color-primary-dark);
  padding: 11px 18px;
}

.ghost-button:hover {
  transform: translateY(-2px);
  border-color: rgba(95, 73, 242, 0.45);
  box-shadow: 0 12px 30px rgba(32, 42, 92, 0.08);
}

.secondary-link {
  color: var(--color-primary-dark);
  font-weight: 800;
}

.hero {
  display: grid;
  grid-template-columns: minmax(0, 1.04fr) minmax(340px, 0.96fr);
  gap: 48px;
  align-items: center;
  padding: 76px 0 54px;
}

.eyebrow {
  margin: 0 0 10px;
  color: var(--color-primary);
  font-size: 0.78rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 22px;
  font-size: clamp(2.6rem, 7vw, 5.7rem);
  line-height: 0.93;
  letter-spacing: -0.065em;
}

h2 {
  margin-bottom: 14px;
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: 1;
  letter-spacing: -0.045em;
}

h3 {
  margin-bottom: 10px;
  font-size: 1.3rem;
}

.hero-text,
.dashboard-hero p,
.showcase-panel p,
.feature-card p,
.create-card-form p,
.form-hint,
.footer p {
  color: var(--color-muted);
  font-size: 1.03rem;
  line-height: 1.75;
}

.hero-text {
  max-width: 660px;
  font-size: 1.18rem;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 34px;
}

.stat-card,
.feature-card,
.showcase-panel,
.dashboard-hero,
.create-card-form,
.cards-panel {
  border: 1px solid rgba(255, 255, 255, 0.82);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: var(--shadow);
  backdrop-filter: blur(14px);
}

.stat-card {
  padding: 18px;
  border-radius: var(--radius-sm);
}

.stat-card strong {
  display: block;
  color: var(--color-primary-dark);
  font-size: 1.35rem;
}

.stat-card span {
  color: var(--color-muted);
  font-size: 0.9rem;
}

.hero-art {
  position: relative;
  min-height: 560px;
}

.phone-mockup {
  position: absolute;
  inset: 20px 44px 0 64px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24px;
  padding: 34px;
  border: 12px solid #111827;
  border-radius: 48px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(238, 243, 255, 0.94)),
    url("data:image/svg+xml,%3Csvg width='120' height='120' viewBox='0 0 120 120' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%235f49f2' fill-opacity='0.08'%3E%3Ccircle cx='24' cy='24' r='10'/%3E%3Ccircle cx='84' cy='70' r='16'/%3E%3C/g%3E%3C/svg%3E");
  box-shadow: 0 36px 90px rgba(17, 24, 39, 0.28);
}

.phone-top {
  position: absolute;
  top: 16px;
  left: 50%;
  width: 96px;
  height: 10px;
  border-radius: 999px;
  background: #111827;
  transform: translateX(-50%);
}

.lesson-card {
  display: grid;
  min-height: 250px;
  place-items: center;
  padding: 28px;
  border-radius: 34px;
  background: linear-gradient(135deg, #5f49f2, #19c6c2);
  color: #fff;
  text-align: center;
}

.lesson-card span,
.lesson-card small {
  opacity: 0.75;
}

.lesson-card strong {
  font-size: clamp(2rem, 4vw, 3.6rem);
  letter-spacing: -0.06em;
}

.mini-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
}

.mini-row span {
  height: 72px;
  border-radius: 20px;
  background: rgba(95, 73, 242, 0.13);
}

.floating-card {
  position: absolute;
  z-index: 2;
  width: 205px;
  padding: 22px;
  border-radius: 24px;
  background: #fff;
  box-shadow: var(--shadow);
}

.floating-card span {
  display: block;
  color: var(--color-primary);
  font-weight: 900;
}

.floating-card strong {
  font-size: 1.45rem;
}

.card-one {
  top: 74px;
  left: 0;
  transform: rotate(-7deg);
}

.card-two {
  right: 0;
  bottom: 60px;
  transform: rotate(8deg);
}

.feature-section,
.showcase {
  padding: 58px 0;
}

.section-heading {
  max-width: 760px;
  margin-bottom: 28px;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 20px;
}

.feature-card {
  padding: 28px;
  border-radius: var(--radius);
}

.feature-icon {
  display: grid;
  width: 54px;
  height: 54px;
  margin-bottom: 22px;
  place-items: center;
  border-radius: 18px;
  background: var(--color-surface-strong);
  color: var(--color-primary);
  font-weight: 900;
}

.showcase-panel {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 320px;
  gap: 34px;
  align-items: center;
  padding: 36px;
  border-radius: var(--radius-lg);
}

.diagram {
  display: grid;
  gap: 12px;
}

.diagram span {
  padding: 16px 20px;
  border-radius: 18px;
  background: #fff;
  color: var(--color-primary-dark);
  font-weight: 900;
  text-align: center;
  box-shadow: 0 12px 34px rgba(32, 42, 92, 0.1);
}

.diagram b {
  width: 4px;
  height: 32px;
  margin: 0 auto;
  border-radius: 999px;
  background: var(--color-accent);
}

.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: grid;
  place-items: center;
  padding: 24px;
  background: rgba(12, 18, 38, 0.62);
  backdrop-filter: blur(8px);
}

.modal-content {
  position: relative;
  width: min(460px, 100%);
}

.close-btn {
  position: absolute;
  top: -52px;
  right: 0;
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  border: 0;
  border-radius: 50%;
  background: #fff;
  color: var(--color-text);
  font-size: 1.8rem;
}

.auth-form,
.create-card-form {
  padding: 30px;
  border-radius: var(--radius);
  background: #fff;
  box-shadow: var(--shadow);
}

.form-group {
  display: grid;
  gap: 8px;
  margin-bottom: 16px;
  color: var(--color-text);
  font-weight: 800;
}

.form-group input {
  width: 100%;
  border: 1px solid var(--color-border);
  border-radius: 16px;
  background: #f9fbff;
  color: var(--color-text);
  padding: 14px 16px;
  outline: none;
}

.form-group input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 4px rgba(95, 73, 242, 0.12);
}

.text-button {
  width: 100%;
  margin-top: 14px;
  background: transparent;
  color: var(--color-primary-dark);
  padding: 10px;
}

.error-message,
.warning-message {
  margin-bottom: 16px;
  border-radius: 14px;
  padding: 12px 14px;
  font-weight: 700;
}

.error-message {
  border: 1px solid rgba(201, 42, 42, 0.18);
  background: #fff1f1;
  color: var(--color-danger);
}

.warning-message {
  border: 1px solid rgba(181, 71, 8, 0.18);
  background: #fff7ed;
  color: var(--color-warning);
}

.dashboard {
  padding: 54px 0 70px;
}

.dashboard-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 24px;
  padding: 34px;
  border-radius: var(--radius-lg);
}

.dashboard-hero h1 {
  max-width: 760px;
  margin-bottom: 14px;
  font-size: clamp(2.2rem, 5vw, 4.1rem);
}

.dashboard-badge {
  display: grid;
  min-width: 160px;
  place-items: center;
  border-radius: 28px;
  background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
  color: #fff;
  padding: 28px;
  text-align: center;
}

.dashboard-badge strong {
  font-size: 3rem;
  line-height: 1;
}

.workspace-grid {
  display: grid;
  grid-template-columns: 360px minmax(0, 1fr);
  gap: 24px;
  align-items: start;
}

.create-card-form,
.cards-panel {
  position: sticky;
  top: 96px;
  border: 1px solid rgba(255, 255, 255, 0.82);
}

.cards-panel {
  position: static;
  min-height: 520px;
  padding: 28px;
  border-radius: var(--radius);
}

.panel-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
}

.loading-label {
  color: var(--color-muted);
  font-weight: 800;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 18px;
}

.card-wrapper {
  display: grid;
  gap: 10px;
}

.study-card {
  position: relative;
  min-height: 230px;
  border: 0;
  background: transparent;
  perspective: 1000px;
}

.card-face {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 14px;
  border-radius: 24px;
  padding: 24px;
  backface-visibility: hidden;
  box-shadow: 0 18px 40px rgba(32, 42, 92, 0.16);
  transition: transform 0.55s ease;
}

.card-face small {
  color: rgba(255, 255, 255, 0.75);
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.card-face strong {
  color: #fff;
  font-size: clamp(1.8rem, 4vw, 2.6rem);
  line-height: 1;
  word-break: break-word;
}

.card-face em {
  color: rgba(255, 255, 255, 0.78);
  font-style: normal;
}

.card-front {
  background: linear-gradient(135deg, #5f49f2, #8266ff);
}

.card-back {
  background: linear-gradient(135deg, #0f9f9c, #19c6c2);
  transform: rotateY(180deg);
}

.study-card.is-flipped .card-front {
  transform: rotateY(180deg);
}

.study-card.is-flipped .card-back {
  transform: rotateY(360deg);
}

.delete-card {
  justify-self: end;
  background: #fff1f1;
  color: var(--color-danger);
  padding: 9px 14px;
}

.delete-card:hover {
  transform: translateY(-1px);
  background: #ffe3e3;
}

.footer {
  padding: 34px 0;
  background: #101828;
  color: #fff;
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.footer p {
  margin: 8px 0 0;
  color: rgba(255, 255, 255, 0.68);
}

.footer a {
  color: #a5f3fc;
  font-weight: 800;
}

@media (max-width: 920px) {
  .nav {
    display: none;
  }

  .hero,
  .showcase-panel,
  .workspace-grid {
    grid-template-columns: 1fr;
  }

  .hero-art {
    min-height: 500px;
  }

  .feature-grid,
  .stats-grid {
    grid-template-columns: 1fr;
  }

  .create-card-form {
    position: static;
  }

  .dashboard-hero,
  .footer-inner {
    align-items: flex-start;
    flex-direction: column;
  }
}

@media (max-width: 620px) {
  .shell {
    width: min(100% - 28px, 1180px);
  }

  .header-inner,
  .header-actions {
    align-items: stretch;
  }

  .header-inner {
    flex-direction: column;
  }

  .header-actions,
  .header-actions button {
    width: 100%;
  }

  .hero {
    padding-top: 42px;
  }

  .hero-art {
    min-height: 390px;
  }

  .phone-mockup {
    inset: 10px 12px 0;
    padding: 20px;
    border-width: 8px;
  }

  .floating-card {
    display: none;
  }

  .showcase-panel,
  .dashboard-hero,
  .cards-panel,
  .auth-form,
  .create-card-form {
    padding: 22px;
  }
}